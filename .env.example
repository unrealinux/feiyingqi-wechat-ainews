# Environment Variables Configuration

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Exa Search API (optional)
EXA_API_KEY=your_exa_api_key_here

# WeChat Official Account
WECHAT_APP_ID=your_wechat_appid
WECHAT_APP_SECRET=your_wechat_appsecret

# WeCom (optional)
WECOM_CORP_ID=your_corp_id
WECOM_CORP_SECRET=your_corp_secret
WECOM_AGENT_ID=your_agent_id

# DingTalk (optional)
DINGTALK_WEBhook=your_dingtalk_webhook
DINGTALK_SECRET=your_dingtalk_secret

# Email (optional)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM_ADDR=your_email@gmail.com
EMAIL_TO_ADDRS=recipient1@example.com,recipient2@example.com
